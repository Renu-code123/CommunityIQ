# ─────────────────────────────────────────────────────────────
# CommunityIQ — Environment Variables Example
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local to Git (it is in .gitignore).
# All variables MUST be prefixed with VITE_ to be available
# in the browser via import.meta.env.VITE_VARIABLE_NAME
# ─────────────────────────────────────────────────────────────

# ── Google AI / Gemini ────────────────────────────────────────
VITE_GEMINI_API_KEY=your_gemini_api_key_here
VITE_GEMINI_MODEL=gemini-2.0-flash

# ── Google Cloud Project ──────────────────────────────────────
VITE_GCP_PROJECT_ID=your-gcp-project-id
VITE_GCP_REGION=asia-south1

# ── Vertex AI (Predictive Models) ────────────────────────────
VITE_VERTEX_AI_ENDPOINT=https://asia-south1-aiplatform.googleapis.com

# ── Google Maps Platform ──────────────────────────────────────
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ── Firebase / Firestore (Real-time Data) ────────────────────
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-gcp-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:abcdef1234567890

# ── BigQuery (Analytics) ─────────────────────────────────────
VITE_BIGQUERY_DATASET=communityiq_analytics
VITE_BIGQUERY_TABLE=telemetry_events

# ── Vertex AI Search (RAG Documents) ─────────────────────────
VITE_VERTEX_SEARCH_APP_ID=your_search_app_id
VITE_VERTEX_SEARCH_LOCATION=global

# ── App Configuration ─────────────────────────────────────────
VITE_APP_NAME=CommunityIQ
VITE_APP_VERSION=1.0.0
VITE_APP_ENV=production
